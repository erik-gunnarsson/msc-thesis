      "index": "b0z",
      "roundness": null,
      "seed": 1150210575,
      "version": 1569,
      "versionNonce": 1441090879,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772564890850,
      "link": null,
      "locked": false,
      "text": "Equation 4 builds on Equation 2 by allowing institutional moderation of automation to differ\nacross industry types, allowing us to examines whether institutional moderation of\nautomation varies across industry types.",
      "fontSize": 10.869578787974405,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Equation 4 builds on Equation 2 by allowing institutional moderation of automation to differ across industry types, allowing us to examines whether institutional moderation of automation varies across industry types.",
