      "boundElements": [],
      "updated": 1772564890850,
      "link": null,
      "locked": false,
      "text": "Equation 3: Bucket heterogeneity (pooled interaction)\n\nDo different types of manufacturing industries respond\ndifferently to robots?",
      "fontSize": 15.977330482483238,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Equation 3: Bucket heterogeneity (pooled interaction)\n\nDo different types of manufacturing industries respond differently to robots?",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "iWW_4egC8nlOsxDC8eSte",
      "type": "text",
      "x": -2258.705807312283,
      "y": 4810.657167351643,
      "width": 498.15349641567985,
      "height": 40.76092045490402,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#e3fafc",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0q",
      "roundness": null,
      "seed": 1414598415,
      "version": 1429,
      "versionNonce": 1915499743,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772564890850,
      "link": null,
      "locked": false,
      "text": "Equation 3 takes the baseline model and  allows the robot effect to differ across industry\nbuckets, providing a more granular view of how automation affects different types of\nmanufacturing industries.",
      "fontSize": 10.869578787974405,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Equation 3 takes the baseline model and  allows the robot effect to differ across industry buckets, providing a more granular view of how automation affects different types of manufacturing industries.",
      "autoResize": false,
      "lineHeight": 1.25
    },
